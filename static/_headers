/*
  Cache-Control: no-store

/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/zh-CN/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/img/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate

/zh-CN/img/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate

/font/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate

/zh-CN/font/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate

/video/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate

/zh-CN/video/*
  ! Cache-Control
  Cache-Control: public, max-age=0, must-revalidate
